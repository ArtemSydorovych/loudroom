{
  "name": "loudroom",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:backend": "tsx watch apps/backend/src/index.ts",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "tsc -p apps/backend/tsconfig.json",
    "build:frontend": "tsc -p apps/frontend/tsconfig.json && vite build --config apps/frontend/vite.config.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "typecheck": "tsc -p apps/backend/tsconfig.json --noEmit && tsc -p apps/frontend/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "db:push": "prisma db push --schema apps/backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema apps/backend/prisma/schema.prisma",
    "postinstall": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@better-auth/core": "^1.6.9",
    "@better-auth/prisma-adapter": "latest",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.60.0",
    "axios": "^1.7.0",
    "better-auth": "latest",
    "better-call": "^1.3.5",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "framer-motion": "^11.12.0",
    "lucide-react": "^0.460.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.13.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
